[{"id":"rss-CNBC-108275140","title":"Iranian projectiles continue to strike Gulf countries; Tehran says new leader appointed","source":"CNBC","publishedAt":"2026-03-08T12:35:45.000Z","url":"https://www.cnbc.com/2026/03/08/iranian-projectiles-continue-to-strike-gulf-countries-infrastructure.html","description":"Bahrain and the United Arab Emirates report more strikes on civilian targets as U.S.-Israeli attacks on Iran continue.","imageUrl":"https://image.cnbcfm.com/api/v1/image/108275142-1772961068439-23_Marina_drone_debris_shot_.jpg?v=1772962502&amp;w=1920&amp;h=1080","theme":"Geopolitics & Conflicts","region":"Other"},{"id":"rss-MarketWatch-WP-MKTW-0004812394","title":"‘When he doesn’t get money, he becomes angry’: My brother has led a life of chaos and financial ruin. What is my moral obligation?","source":"MarketWatch","publishedAt":"2026-03-08T11:58:00.000Z","url":"https://www.marketwatch.com/story/when-he-doesnt-get-money-he-becomes-angry-my-brother-has-led-a-life-of-chaos-and-financial-ruin-what-is-my-moral-obligation-ac5efa9d?mod=mw_rss_topstories","description":"“Without clear distance and boundaries, he will pull me down with him.”","imageUrl":"https://images.mktw.net/im-05665090","theme":"Emerging","emerging_label":"","region":"Other"},{"id":"rss-CNBC-108274161","title":"Global week ahead: Diplomacy in ruins as G7 meets on Iran","source":"CNBC","publishedAt":"2026-03-08T11:12:45.000Z","url":"https://www.cnbc.com/2026/03/08/global-week-ahead-diplomacy-in-ruins-as-g7-meets-on-iran.html","description":"G7 finance ministers and central bank governors are set to convene for a key meeting as diplomatic tensions escalate over the Iran conflict.","imageUrl":"https://image.cnbcfm.com/api/v1/image/108272185-17724755852026-03-02t172324z_475686089_rc2gwja9q6uq_rtrmadp_0_iran-crisis.jpeg?v=1772475630&amp;w=1920&amp;h=1080","theme":"Geopolitics & Conflicts","region":"Global"},{"id":"rss-MarketWatch-WP-MKTW-0004820374","title":"‘My mother refuses to turn on the heat’: Will America’s war with Iran really push up our utility bills?","source":"MarketWatch","publishedAt":"2026-03-08T10:56:00.000Z","url":"https://www.marketwatch.com/story/my-mother-refuses-to-turn-on-the-heat-will-americas-war-with-iran-really-push-up-our-utility-bills-df746548?mod=mw_rss_topstories","description":"“She is reading alarmist headlines about Iran in the newspapers.”","imageUrl":"https://images.mktw.net/im-38949837","theme":"Geopolitics & Conflicts","region":"US"},{"id":"rss-MarketWatch-WP-MKTW-0004819525","title":"‘He has been emotionally abusive’: My father, 75, is on oxygen and destitute. What do I owe him?","source":"MarketWatch","publishedAt":"2026-03-08T10:55:00.000Z","url":"https://www.marketwatch.com/story/he-has-been-emotionally-abusive-my-father-75-is-on-oxygen-and-destitute-what-do-i-owe-him-eb21e873?mod=mw_rss_topstories","description":"“He has less than $20,000 to his name and no income besides Social Security.”","imageUrl":"https://images.mktw.net/im-52827027","theme":"Emerging","emerging_label":"","region":"Other"},{"id":"rss-CNBC-108275138","title":"China says 'thorough preparations' needed as Trump-Xi meeting hangs in the balance amid Iran war","source":"CNBC","publishedAt":"2026-03-08T07:17:53.000Z","url":"https://www.cnbc.com/2026/03/08/china-says-thorough-preparations-needed-ahead-of-trump-xi-meeting.html","description":"China's top diplomat Wang Yi signaled preparations are underway for a planned meeting between the presidents of the U.S. and China.","imageUrl":"https://image.cnbcfm.com/api/v1/image/108275139-1772946521911-gettyimages-2265348376-vcg111626512960.jpeg?v=1772946536&amp;w=1920&amp;h=1080","theme":"Geopolitics & Conflicts","region":"China"},{"id":"rss-BBC Business-https://www.bbc.com/news/articles/c14m5g18d5jo#4","title":"Why holiday meal money for cash-strapped parents is back on the menu","source":"BBC Business","publishedAt":"2026-03-08T06:50:21.000Z","url":"https://www.bbc.com/news/articles/c14m5g18d5jo?at_medium=RSS&at_